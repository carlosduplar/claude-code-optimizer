{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "EXAMPLE FILE - Copy this to ~/.claude/settings.json (NOT the project directory)",
  "autoCompactEnabled": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/pretooluse.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/posttooluse.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
